# Brother Pharmach MDM - Windows Server Docker environment
# Copy to .env in hmdm-server before running docker compose

# Database
DB_NAME=hmdm
DB_USER=hmdm
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_PORT=5432

# Public URL used by devices/admin panel
# Example: http://10.0.0.25:8080 or https://mdm.company.com
BASE_URL=http://YOUR_WINDOWS_SERVER_IP_OR_DOMAIN:8080

# Host ports
HTTP_PORT=8080
MQTT_PORT=31000

# Security secrets (change before production)
HASH_SECRET=CHANGE_ME_RANDOM_HASH_SECRET
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
SECURE_ENROLLMENT=1

# MQTT
MQTT_AUTH=1
MQTT_MESSAGE_DELAY=0

# Optional SMTP
ADMIN_EMAIL=admin@company.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=0
SMTP_STARTTLS=1
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com
