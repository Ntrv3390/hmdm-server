# =============================================================================
#  Brother Pharmach MDM – Environment Configuration
#  Copy this file to .env and adjust values BEFORE running docker compose up -d
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=hmdm
DB_USER=hmdm
# IMPORTANT: Change this password before deploying!
DB_PASSWORD=strongpassword123
DB_PORT=5432

# ── Application ───────────────────────────────────────────────────────────────
# Public URL where clients (Android devices AND admin browsers) reach the server.
# Use your server's public IP or domain name.
# Examples:
#   http://192.168.1.100:8080
#   https://mdm.yourcompany.com
BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN:8080

# Ports exposed on the host. Change only if these ports are already in use.
HTTP_PORT=8080
MQTT_PORT=31000

# ── Security ──────────────────────────────────────────────────────────────────
# Change these secrets before production deployment!
HASH_SECRET=changeme-replace-with-random-string
JWT_SECRET=20c68f0d9185b1d18cf6add1e8b491fd89529a44
SECURE_ENROLLMENT=0

# Set to 1 to enable MQTT authentication (recommended)
MQTT_AUTH=1
MQTT_MESSAGE_DELAY=0

# ── SMTP – Password Recovery (optional) ───────────────────────────────────────
# Leave SMTP_HOST empty to disable password recovery email.
ADMIN_EMAIL=admin@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=0
SMTP_STARTTLS=1
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com
